# ============================================================
# Blastgate .gitignore
# Covers: PlatformIO firmware, Python desktop, Flutter mobile
# ============================================================

# ── PlatformIO ──────────────────────────────────────────────
.pio/
.pioenvs/
.piolibdeps/
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch
.vscode/extensions.json

# CMake cache from PIO/Arduino IDE
CMakeListsPrivate.txt
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# ── Python (desktop/) ───────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
desktop/build/
desktop/dist/
*.egg-info/
*.egg
.eggs/

# PyInstaller — .spec files are kept (reproducibility), output ignored
# desktop/*.spec     ← uncomment if you regenerate them

# Virtual envs
venv/
.venv/
env/
ENV/

# Test/lint cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*

# Local runtime state
desktop/logs/
desktop/blastgate_gui_config.json     # user-specific IP / token / preferences

# ── Flutter / Dart (mobile/) ────────────────────────────────
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.packages
mobile/.pub-cache/
mobile/.pub/
mobile/build/

# Platform-generated, regenerated per machine
mobile/android/.gradle/
mobile/android/local.properties
mobile/android/key.properties
mobile/android/app/release/
mobile/android/captures/
mobile/android/**/GeneratedPluginRegistrant.*
mobile/android/app/.cxx/

mobile/ios/Flutter/Flutter.framework
mobile/ios/Flutter/Flutter.podspec
mobile/ios/Flutter/Generated.xcconfig
mobile/ios/Flutter/app.flx
mobile/ios/Flutter/app.zip
mobile/ios/Flutter/flutter_assets/
mobile/ios/Flutter/flutter_export_environment.sh
mobile/ios/ServiceDefinitions.json
mobile/ios/Runner/GeneratedPluginRegistrant.*
mobile/ios/Pods/
mobile/ios/.symlinks/

mobile/linux/flutter/ephemeral/
mobile/macos/Flutter/ephemeral/
mobile/macos/Pods/
mobile/macos/.symlinks/
mobile/windows/flutter/ephemeral/

# IDE
.idea/
*.iml
*.ipr
*.iws

# ── Secrets / sensitive ─────────────────────────────────────
# OTA token, WiFi creds, signing keys must never end up in git
*.pem
*.p12
*.keystore
*.jks
.env
.env.*

# ── OS noise ────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ── Editor backup files ─────────────────────────────────────
*.orig
*.bak

# ── Firmware build outputs (large binaries — released via GH Releases) ──
# We commit source; binaries are produced by `pio run` and uploaded to releases
firmware/**/*.bin
firmware/**/*.elf
firmware/**/*.map
firmware/**/*.hex
